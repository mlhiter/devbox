{
  "name": "devbox-sealos",
  "displayName": "devbox",
  "description": "help code for cloud sealos",
  "version": "0.0.1",
  "publisher": "mlhiter",
  "icon": "https://raw.githubusercontent.com/mlhiter/typora-images/master/202407181510292.png",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "authentication": [
      {
        "label": "Devbox",
        "id": "devbox"
      }
    ],
    "configuration": [
      {
        "title": "Devbox",
        "properties": {
          "devbox.host": {
            "type": "string",
            "description": "Devbox Service URL. Update this if you are using a Devbox self-hosted installation.",
            "default": "https://gitpod.io/",
            "scope": "application"
          },
          "devbox.lsshExtensionIpcPort": {
            "type": "number",
            "description": "The port to use for the local SSH ipc server.",
            "scope": "application"
          },
          "devbox.lssh.logLevel": {
            "type": "string",
            "description": "The log level for ssh proxy.",
            "scope": "application",
            "enum": [
              "none",
              "debug"
            ],
            "default": "none"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "devbox.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {}
}
